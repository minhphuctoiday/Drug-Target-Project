# Protein Target Identification Platform
# Copy this file to `.env` and fill real values locally. Do not commit `.env`.

# Runtime
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true
LOG_LEVEL=info

# Artifact directories
PROJECT_ROOT=D:\drug_target_project
OUTPUTS_DIR=D:\drug_target_project\outputs
REFINED_DIR=D:\drug_target_project\data\refined
MODEL_ARTIFACT_PATH=D:\drug_target_project\outputs\ml_models\best_tumor_normal_model_strict.joblib

# MongoDB local, optional.
# The app can run without MongoDB. When enabled, prediction/chat/report events can be logged.
MONGODB_ENABLED=false
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=drugtarget_luad
MONGODB_PREDICTIONS_COLLECTION=predictions
MONGODB_CHAT_COLLECTION=chat_events
MONGODB_REPORTS_COLLECTION=protein_target_reports

# Optional LLM-backed RAG.
# Leave disabled for local retrieval/template mode.
RAG_MODE=gemini
RAG_KNOWLEDGE_BASE_PATH=D:\drug_target_project\docs\project_knowledge_base.md
RAG_INDEX_PATH=D:\drug_target_project\outputs\rag\project_knowledge_index.json
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=160
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional legacy OpenAI config, only used if RAG_MODE=openai in future code.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional external biomedical APIs, reserved for future annotation expansion.
# Current project does not fetch or alter input omics data.
OPENTARGETS_API_URL=https://api.platform.opentargets.org/api/v4/graphql
DGIDB_API_URL=https://dgidb.org/api/graphql
CHEMBL_API_URL=https://www.ebi.ac.uk/chembl/api/data

# Security for future deployment
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
API_TOKEN=
