# Copy this file to .env and add your Gemini API key.
GEMINI_API_KEY=

# Gemini RAG models
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSION=768
GEMINI_MAX_OUTPUT_TOKENS=1400

# Knowledge base and ChromaDB
RAG_KNOWLEDGE_PATH=paper/drug_target_project_rag_knowledge_base.md
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=drug_target_project_knowledge
RAG_VECTOR_EXPORT_PATH=src/backend/rag/drug_target_project_knowledge_export.json
RAG_TOP_K=6
RAG_MAX_CONTEXT_CHARS=24000
